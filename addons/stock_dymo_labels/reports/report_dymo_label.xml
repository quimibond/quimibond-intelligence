<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 72mm;
                            font-family: 'Helvetica', Arial, sans-serif;
                            text-align: center;
                            padding-top: 5mm;
                        }
                        .label-ref { font-size: 42px; font-weight: bold; display: block; margin-bottom: 5px; }
                        .label-name { font-size: 42px; display: block; margin-bottom: 10px; height: 40px; overflow: hidden; }
                        .label-data { font-size: 42px; font-weight: bold; display: block; margin-bottom: 5px; }
                        
                        /* Contenedor del código de barras optimizado */
                        .barcode-container {
                            margin: 15px auto 0 auto;
                            width: 90%; /* Deja un 5% de margen blanco a cada lado (Quiet Zone) */
                            background-color: white;
                        }
                        .barcode-container img {
                            width: 100% !important;
                            height: 35mm !important; /* Altura generosa para fácil lectura */
                            display: block;
                            margin: 0 auto;
                        }
                        .lot-footer {
                            font-size: 16px;
                            font-weight: bold;
                            margin-top: 10px;
                        }
                    </style>

                    <div class="label-container">
                        <span class="label-ref">REF: <t t-esc="line.product_id.default_code or 'N/A'"/></span>
                        <span class="label-name"><t t-esc="line.product_id.name"/></span>
                        
                        <span class="label-data">
                            LOTE: <t t-esc="line.lot_id.name"/> | CANT: <t t-esc="line.quantity"/>
                        </span>
                        <span class="label-data" style="font-size: 42px;">
                            CAJA: <t t-esc="line.lot_id.name[-4:] if line.lot_id else '0000'"/>
                        </span>

                        <div class="barcode-container">
                            <t t-if="line.lot_id">
                                <img t-att-src="'/report/barcode/?symbology=Code128&amp;value=' + str(line.lot_id.name) + '&amp;width=1200&amp;height=300'"/>
                                <div class="lot-footer">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>