<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 70mm;
                            font-family: 'Helvetica', Arial, sans-serif;
                            color: black;
                            padding: 5mm;
                            /* CENTRADO GLOBAL */
                            text-align: center; 
                        }
                        .label-ref {
                            font-size: 42px;
                            font-weight: bold;
                            margin-bottom: 5px;
                            display: block;
                        }
                        .label-name {
                            font-size: 42px;
                            line-height: 1.2;
                            margin-bottom: 8px;
                            display: block;
                            width: 100%;
                            word-wrap: break-word;
                        }
                        .label-data {
                            font-size: 42px;
                            margin-bottom: 5px;
                            display: block;
                        }
                        .barcode-box {
                            margin-top: 20px;
                            width: 100%;
                            display: flex;
                            flex-direction: column;
                            align-items: center;
                        }
                        /* Asegura que la imagen del código de barras se centre */
                        .barcode-box img {
                            display: block;
                            margin: 0 auto;
                        }
                    </style>

                    <div class="label-container">
                        <span class="label-ref">
                            Ref: <t t-esc="line.product_id.default_code or 'N/A'"/>
                        </span>
                        
                        <span class="label-name">
                            <t t-esc="line.product_id.name"/>
                        </span>
                        
                        <span class="label-data">
                            <strong>Lote:</strong> <t t-esc="line.lot_id.name"/>
                        </span>
                        
                        <span class="label-data">
                            <strong>Cant:</strong> <t t-esc="line.quantity"/> 
                            <span style="margin-left: 15px;">
                                <strong>Caja:</strong> <t t-esc="line.lot_id.name[-4:] if line.lot_id.name else '0000'"/>
                            </span>
                        </span>

                        <div class="barcode-box">
                            <t t-if="line.lot_id.name">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 600, 'height': 120, 'img_style': 'width:90%;height:25mm;display:block;margin:auto;'}"/>
                                <div style="font-size: 12px; margin-top: 5px;"><t t-esc="line.lot_id.name"/></div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>