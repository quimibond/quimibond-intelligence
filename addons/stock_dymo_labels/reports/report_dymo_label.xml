<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 72mm;
                            text-align: center;
                            font-family: 'Arial', sans-serif;
                            color: black;
                            padding-top: 2mm;
                        }
                        .text-42 {
                            font-size: 42px;
                            font-weight: bold;
                            display: block;
                            margin-bottom: 5px;
                            white-space: nowrap;
                            overflow: hidden;
                        }
                        .barcode-zone {
                            margin-top: 15px;
                            width: 100%;
                            display: flex;
                            justify-content: center;
                        }
                        /* ESTRECHAMOS EL CÓDIGO PARA MEJOR LECTURA */
                        .barcode-zone img {
                            width: 60% !important; /* Reducido del 90% al 60% */
                            height: 22mm !important;
                            display: block;
                            margin: 0 auto;
                        }
                        .lot-footer {
                            font-size: 30px;
                            font-weight: bold;
                            margin-top: 5px;
                        }
                    </style>

                    <div class="label-container">
                        <span class="text-42">
                            REF: <t t-esc="line.product_id.default_code or 'N/A'"/>
                        </span>
                        
                        <span class="text-42">
                            <t t-esc="line.product_id.name"/>
                        </span>
                        
                        <span class="text-42">
                            LOTE: <t t-esc="line.lot_id.name"/>
                        </span>
                        
                        <span class="text-42">
                            CAJA: <t t-esc="line.lot_id.name[-4:] if line.lot_id else '0000'"/> 
                            <span style="margin-left: 20px;">CANT: <t t-esc="int(line.quantity)"/></span>
                        </span>

                        <div class="barcode-zone">
                            <t t-if="line.lot_id">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 400, 'height': 80, 'img_style': 'width:90%; height:35px;'}"/>
                            </t>
                        </div>
                        <div class="lot-footer">
                            <t t-esc="line.lot_id.name"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>