<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 72mm;
                            text-align: center;
                            font-family: 'Arial', sans-serif;
                            color: black;
                            padding-top: 5mm;
                        }
                        .text-large {
                            font-size: 42px; /* Tamaño solicitado */
                            font-weight: bold;
                            display: block;
                            margin-bottom: 10px;
                            white-space: nowrap;
                            overflow: hidden;
                        }
                        .barcode-zone {
                            margin-top: 20px;
                            width: 100%;
                        }
                        /* Mantiene el código de barras nítido */
                        .barcode-zone img {
                            width: 90% !important;
                            height: 25mm !important;
                            display: block;
                            margin: 0 auto;
                        }
                    </style>

                    <div class="label-container">
                        <span class="text-large">
                            REF: <t t-esc="line.product_id.default_code or 'N/A'"/>
                        </span>
                        
                        <span class="text-large">
                            <t t-esc="line.product_id.name"/>
                        </span>
                        
                        <span class="text-large">
                            LOTE: <t t-esc="line.lot_id.name"/>
                        </span>
                        
                        <span class="text-large">
                            CAJA: <t t-esc="line.lot_id.name[-4:] if line.lot_id else '0000'"/> 
                            <span style="margin-left: 30px;">CANT: <t t-esc="int(line.quantity)"/></span>
                        </span>

                        <div class="barcode-zone">
                            <t t-if="line.lot_id">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 1200, 'height': 300, 'img_style': 'width:90%; height:25mm;'}"/>
                                <div style="font-size: 25px; font-weight: bold; margin-top: 5px;">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>