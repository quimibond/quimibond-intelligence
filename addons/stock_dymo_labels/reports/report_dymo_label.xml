<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="line">
                <div class="page" style="padding: 0; margin: 0;">
                    <div style="width: 100%; text-align: center; font-family: sans-serif; color: black;">
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1; margin-top: 5px;">
                             <t t-esc="line.product_id.default_code or 'N/A'"/>
                        </div>
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1; white-space: nowrap; overflow: hidden;">
                            <t t-esc="line.product_id.name"/>
                        </div>
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1;">
                            Lote: <t t-esc="line.lot_id.name"/>
                        </div>
                        
                        <div style="font-size: 42px; font-weight: bold; line-height: 1;">
                            Caja: <t t-esc="line.lot_id.name[-4:] if line.lot_id else '0000'"/> 
                            <span style="margin-left: 15px;">Cant: <t t-esc="int(line.quantity)"/></span>
                        </div>

                        <div style="margin-top: 10px; width: 100%;">
                            <t t-if="line.lot_id">
                                <img t-att-src="'/report/barcode/?symbology=Code128&amp;value=' + quote_plus(line.lot_id.name) + '&amp;width=600&amp;height=150&amp;humanreadable=0'" 
                                     style="width: 70%; height: 20mm; display: block; margin: 0 auto;"/>
                                <div style="font-size: 20px; font-weight: bold; margin-top: 2px;">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>