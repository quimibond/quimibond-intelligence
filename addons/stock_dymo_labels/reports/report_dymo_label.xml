<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_label_dymo_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="line">
                <t t-call="web.basic_layout">
                    <style>
                        .label-container {
                            width: 100%;
                            height: 72mm;
                            font-family: 'Helvetica', Arial, sans-serif;
                            text-align: center;
                            padding-top: 5mm;
                            color: black;
                        }
                        .label-ref { font-size: 24px; font-weight: bold; display: block; margin-bottom: 8px; }
                        .label-name { font-size: 18px; display: block; margin-bottom: 12px; max-height: 45px; overflow: hidden; line-height: 1.2; }
                        .label-data { font-size: 19px; font-weight: bold; display: block; margin-bottom: 8px; }
                        
                        /* Contenedor optimizado para lectura láser */
                        .barcode-box {
                            margin: 10px auto;
                            width: 94%; /* Espacio de silencio (Quiet Zone) a los lados */
                        }
                        
                        /* Forzar que el widget de Odoo se expanda correctamente */
                        .barcode-box img {
                            width: 100% !important;
                            height: 38mm !important; /* Altura suficiente para el lector */
                            display: block;
                            margin: 0 auto;
                        }
                        .lot-footer {
                            font-size: 18px;
                            font-weight: bold;
                            margin-top: 8px;
                            letter-spacing: 2px;
                        }
                    </style>

                    <div class="label-container">
                        <span class="label-ref">REF: <t t-esc="line.product_id.default_code or 'N/A'"/></span>
                        
                        <span class="label-name"><t t-esc="line.product_id.name"/></span>
                        
                        <span class="label-data">LOTE: <t t-esc="line.lot_id.name"/></span>
                        
                        <span class="label-data">
                            CANT: <t t-esc="line.quantity"/> 
                            <span style="margin-left: 20px;">
                                CAJA: <t t-esc="line.lot_id.name[-4:] if line.lot_id and line.lot_id.name else '0000'"/>
                            </span>
                        </span>

                        <div class="barcode-box">
                            <t t-if="line.lot_id">
                                <span t-field="line.lot_id.name" 
                                      t-options="{'widget': 'barcode', 'symbology': 'Code128', 'width': 1200, 'height': 300, 'img_style': 'width:100%; height:38mm;'}"/>
                                <div class="lot-footer">
                                    <t t-esc="line.lot_id.name"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>