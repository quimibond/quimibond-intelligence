    <record id="action_report_dymo_picking_label" model="ir.actions.report">
        <field name="name">Etiquetas Dymo Recepción</field>
        <field name="model">stock.move.line</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_dymo_labels.report_label_dymo_custom</field>
        <field name="report_file">stock_dymo_labels.report_label_dymo_custom</field>
