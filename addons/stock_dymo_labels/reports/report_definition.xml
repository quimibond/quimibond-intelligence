<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_dymo_57x32" model="report.paperformat">
        <field name="name">Dymo 57x32mm</field>
        <field name="default" eval="True" />
        <field name="format">custom</field>
        <field name="page_height">32</field>
        <field name="page_width">57</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_dymo_picking_label" model="ir.actions.report">
        <field name="name">Etiquetas Dymo Recepción</field>
        <field name="model">stock.move.line</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_dymo_labels.report_dymo_label_template</field>
        <field name="report_file">stock_dymo_labels.report_dymo_label_template</field>
        <field name="paperformat_id" ref="paperformat_dymo_57x32"/>
        <field name="binding_model_id" eval="False"/>
    </record>
</odoo>