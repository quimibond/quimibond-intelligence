<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_inherit_textil_direct" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.textil.direct</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="after">
                <field name="show_barcode_scan" invisible="1"/>
                <div class="alert alert-info" role="alert" 
                     invisible="not show_barcode_scan or state in ['done', 'cancel']">
                    <group>
                        <field name="barcode_scan_batch" 
                               placeholder="COLOQUE EL CURSOR AQUÍ Y ESCANEE..." 
                               default_focus="1"
                               autocomplete="off"
                               force_save="1"/>
                    </group>
                    <p style="margin-bottom:0px;">
                        <strong>Surtido Toluca:</strong> Al escanear, el sistema procesará el lote y recargará la página automáticamente.
                    </p>
                </div>
            </xpath>
        </field>
    </record>
</odoo>